{
  "extends": ["../../.eslintrc.json", "plugin:@nrwl/nx/react", "eslint-config-postcss"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "parserOptions": {
        "project": ["apps/frontend/tsconfig.*?.json"]
      },
      "rules": {
        "@typescript-eslint/no-unused-vars": ["warn", { "varsIgnorePattern": "$import*|^_", "caughtErrorsIgnorePattern": "^_" }]
      }
    }
  ]
}
